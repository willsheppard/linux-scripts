# Install packages
apt update
apt install gh
gh auth login

# Install repos
cd ~
mkdir alt
mkdir dev
gh repo clone linux-scripts alt/linux-scripts
gh repo clone dotfiles alt/dotfiles

# Setup links
echo "" >> .bashrc
echo "# WS custom setup" >> .bashrc
echo "source ~/alt/dotfiles/.bashrc" >> .bashrc
ln -s ~/alt/dotfiles/.gitconfig .gitconfig
ln -s ~/alt/dotfiles/.vimrc .vimrc

# Install other packages
wget 'https://github.com/asdf-vm/asdf/releases/download/v0.18.1/asdf-v0.18.1-linux-arm64.tar.gz'
tar -xpvzf asdf*.gz
mv asdf ~/alt/linux-scripts/bin/
rm asdf*.gz
